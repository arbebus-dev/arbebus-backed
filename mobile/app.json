{
  "expo": {
    "name": "Arbebus",
    "slug": "arbebus-monorepo",
    "version": "1.0.0",
    "scheme": "arbebus",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "plugins": ["expo-router", "expo-splash-screen"],
    "ios": {
      "bundleIdentifier": "com.arbebus.app",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Arbebus naudoja jūsų vietą, kad parodytų artimiausias stoteles ir maršrutus.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Arbebus naudoja jūsų vietą kelionės navigacijai ir pranešimams."
      }
    },
    "android": {
      "package": "com.arbebus.app",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "extra": {
      "eas": {
        "projectId": "3ff2bb3c-494a-4b7e-9aa8-be2f5bfc6dd5"
      }
    }
  }
}
