{
  "expo": {
    "name": "Arbebus",
    "slug": "arbebus",
    "scheme": "arbebus",
    "version": "1.0.1",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-notifications"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#03070B"
    },
    "ios": {
      "bundleIdentifier": "com.arbebus.app",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "buildNumber": "115",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification",
          "location",
          "fetch",
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "Arbebus naudoja tavo lokaciją maršrutams, artimiausiems autobusams ir tiksliems kelionės priminimams.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Arbebus gali naudoti lokaciją fone, kad primintų kada išeiti ir perskaičiuotų kelionės priminimus.",
        "NSUserNotificationsUsageDescription": "Arbebus siunčia kelionės priminimus ir įlipimo / išlipimo pranešimus."
      }
    },
    "android": {
      "package": "com.arbebus.app",
      "versionCode": 7,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#05070d"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c06c6105-b193-40a0-995d-18c86f91f089"
      },
      "API_BASE_URL": "https://arbebus-backed.onrender.com",
      "EXPO_PUBLIC_API_BASE_URL": "https://arbebus-backed.onrender.com"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c06c6105-b193-40a0-995d-18c86f91f089"
    }
  }
}
