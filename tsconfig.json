{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "core/**/*.ts", "core/**/*.tsx", "constants/**/*.ts"],
  "exclude": ["node_modules", "_legacy_removed", "backend", "ios", "android", "dist", "build"]
}
