{
  "expo": {
    "name": "Arbebus",
    "slug": "arbebus",
    "scheme": "arbebus",
    "version": "1.0.1",
    "newArchEnabled": true,
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-router"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#05070d"
    },
    "ios": {
      "bundleIdentifier": "com.arbebus.app",
      "supportsTablet": true,
      "buildNumber": "67",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Arbebus naudoja tavo lokaciją autobusų maršrutams, artimiausioms stotelėms ir ETA."
      }
    },
    "android": {
      "package": "com.arbebus.app",
      "versionCode": 6,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#05070d"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c06c6105-b193-40a0-995d-18c86f91f089"
      }
    }
  }
}
